{
  "name": "campus-vlan-rollout",
  "fail_fast": true,
  "rollback_on_stage_failure": true,
  "rollback_completed_stages_on_failure": false,
  "stages": [
    {
      "name": "core",
      "strategy": "serial",
      "jobs": [
        {
          "name": "core-job",
          "strategy": "serial",
          "target_groups": ["core"],
          "action": {
            "kind": "tx_workflow",
            "workflow_template_name": "campus-core-vlan"
          }
        }
      ]
    },
    {
      "name": "access",
      "strategy": "serial",
      "jobs": [
        {
          "name": "access-job",
          "strategy": "parallel",
          "max_parallel": 10,
          "target_groups": ["access"],
          "action": {
            "kind": "tx_workflow",
            "workflow_template_name": "campus-access-vlan"
          }
        }
      ]
    }
  ]
}
