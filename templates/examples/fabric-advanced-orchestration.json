{
  "name": "fabric-service-rollout-advanced",
  "fail_fast": true,
  "rollback_on_stage_failure": true,
  "rollback_completed_stages_on_failure": true,
  "stages": [
    {
      "name": "core-services",
      "strategy": "serial",
      "jobs": [
        {
          "name": "core-services-job",
          "strategy": "serial",
          "target_groups": ["core"],
          "action": {
            "kind": "tx_workflow",
            "workflow_template_name": "fabric-service-rollout"
          }
        }
      ]
    },
    {
      "name": "distribution-guardrails",
      "strategy": "serial",
      "fail_fast": false,
      "jobs": [
        {
          "name": "distribution-guardrails-job",
          "strategy": "parallel",
          "max_parallel": 2,
          "target_groups": ["distribution"],
          "action": {
            "kind": "tx_workflow",
            "workflow_template_name": "distribution-guardrails"
          }
        }
      ]
    },
    {
      "name": "access-rollout",
      "strategy": "serial",
      "jobs": [
        {
          "name": "access-rollout-job",
          "strategy": "parallel",
          "max_parallel": 8,
          "target_groups": ["access"],
          "targets": ["qa-lab-sw"],
          "action": {
            "kind": "tx_workflow",
            "workflow_template_name": "access-service-vlans"
          }
        }
      ]
    },
    {
      "name": "edge-cleanup",
      "strategy": "serial",
      "fail_fast": false,
      "jobs": [
        {
          "name": "edge-cleanup-job",
          "strategy": "serial",
          "targets": ["edge-fw-01", "edge-fw-02"],
          "action": {
            "kind": "tx_workflow",
            "workflow_template_name": "edge-cleanup"
          }
        }
      ]
    }
  ]
}
