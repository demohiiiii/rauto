{
  "name": "linux-image-rollout",
  "fail_fast": true,
  "stages": [
    {
      "name": "source-export-and-transfer",
      "strategy": "serial",
      "jobs": [
        {
          "name": "source-export-and-transfer-job",
          "strategy": "serial",
          "targets": [
            "linux-source"
          ],
          "action": {
            "kind": "tx_workflow",
            "workflow_file": "./linux-image-export-and-transfer-workflow.json"
          }
        }
      ]
    },
    {
      "name": "target-load-and-restart",
      "strategy": "serial",
      "jobs": [
        {
          "name": "target-load-and-restart-job",
          "strategy": "serial",
          "targets": [
            "linux-target"
          ],
          "action": {
            "kind": "tx_workflow",
            "workflow_file": "./linux-image-load-and-restart-workflow.json"
          }
        }
      ]
    }
  ]
}
