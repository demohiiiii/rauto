{
  "name": "fabric-service-rollout",
  "fail_fast": true,
  "blocks": [
    {
      "name": "vlan-and-svi",
      "kind": "config",
      "fail_fast": true,
      "rollback_policy": {
        "whole_resource": {
          "rollback": {
            "kind": "command",
            "mode": "Config",
            "command": "default interface vlan 310",
            "timeout": 15
          },
          "trigger_step_index": 0
        }
      },
      "steps": [
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "vlan 310",
            "timeout": 10
          },
          "rollback": null
        },
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "name APP-310",
            "timeout": 10
          },
          "rollback": null
        },
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "interface vlan 310",
            "timeout": 10
          },
          "rollback": null
        },
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "description APP gateway",
            "timeout": 10
          },
          "rollback": null
        },
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "ip address 10.31.0.1 255.255.255.0",
            "timeout": 10
          },
          "rollback": null
        }
      ]
    },
    {
      "name": "trunk-allow-list",
      "kind": "config",
      "fail_fast": true,
      "rollback_policy": "per_step",
      "steps": [
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "interface port-channel10",
            "timeout": 10
          },
          "rollback": {
            "kind": "command",
            "mode": "Config",
            "command": "default interface port-channel10",
            "timeout": 10
          }
        },
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "switchport trunk allowed vlan add 310",
            "timeout": 10
          },
          "rollback": {
            "kind": "command",
            "mode": "Config",
            "command": "switchport trunk allowed vlan remove 310",
            "timeout": 10
          }
        }
      ]
    },
    {
      "name": "edge-uplink-backup",
      "kind": "config",
      "fail_fast": false,
      "rollback_policy": "per_step",
      "steps": [
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "interface ethernet1/49",
            "timeout": 10
          },
          "rollback": {
            "kind": "command",
            "mode": "Config",
            "command": "default interface ethernet1/49",
            "timeout": 10
          }
        },
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "description backup-uplink-for-app310",
            "timeout": 10
          },
          "rollback": {
            "kind": "command",
            "mode": "Config",
            "command": "no description",
            "timeout": 10
          }
        }
      ]
    }
  ]
}
