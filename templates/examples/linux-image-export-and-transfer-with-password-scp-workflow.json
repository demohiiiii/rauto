{
  "name": "linux-image-export-and-transfer-with-password-scp",
  "fail_fast": true,
  "blocks": [
    {
      "name": "export-and-copy",
      "kind": "config",
      "fail_fast": true,
      "rollback_policy": "per_step",
      "steps": [
        {
          "run": {
            "kind": "command",
            "mode": "User",
            "command": "docker save myrepo/myapp:1.2.3 -o /tmp/myapp-1.2.3.tar",
            "timeout": 1800
          },
          "rollback": null
        },
        {
          "run": {
            "kind": "flow",
            "stop_on_error": true,
            "steps": [
              {
                "mode": "User",
                "command": "scp /tmp/myapp-1.2.3.tar deploy@10.0.0.22:/tmp/myapp-1.2.3.tar",
                "timeout": 1800,
                "interaction": {
                  "prompts": [
                    {
                      "patterns": [
                        "(?i)^are you sure you want to continue connecting.*$"
                      ],
                      "response": "yes\n",
                      "record_input": true
                    },
                    {
                      "patterns": [
                        "(?i)^.*password.*:\\s*$"
                      ],
                      "response": "replace-with-real-scp-password\n",
                      "record_input": false
                    }
                  ]
                }
              }
            ]
          },
          "rollback": null
        }
      ]
    }
  ]
}
