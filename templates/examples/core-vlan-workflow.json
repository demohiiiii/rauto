            "mode": "Config",
            "command": "no vlan 120",
            "timeout": 10
          }
        },
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "name STAFF",
            "timeout": 10
          },
          "rollback": {
            "kind": "command",
            "mode": "Config",
            "command": "no name STAFF",
            "timeout": 10
          }
        }
      ]
    },
    {
      "name": "create-svi",
      "kind": "config",
      "fail_fast": true,
      "rollback_policy": {
        "whole_resource": {
          "rollback": {
            "kind": "command",
            "mode": "Config",
            "command": "default interface vlan 120",
            "timeout": 10
          }
        }
      },
      "steps": [
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "interface vlan 120",
            "timeout": 10
          },
          "rollback": null
        },
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "description STAFF gateway",
            "timeout": 10
          },
          "rollback": null
        },
        {
          "run": {
            "kind": "command",
            "mode": "Config",
            "command": "ip address 10.120.0.1 255.255.255.0",
            "timeout": 10
          },
          "rollback": null
        }
      ]
    }
  ]
