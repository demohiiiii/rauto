{
  "defaults": {
    "username": "ops",
    "port": 22,
    "device_profile": "cisco",
    "vars": {
      "tenant": "dc-east",
      "change_window": "sat-0200"
    }
  },
  "groups": {
    "core": {
      "defaults": {
        "vars": {
          "role": "core",
          "change_id": "CHG-20260311-A"
        }
      },
      "targets": [
        {
          "connection": "core-01",
          "vars": {
            "hostname": "core-01"
          }
        },
        {
          "connection": "core-02",
          "vars": {
            "hostname": "core-02"
          }
        }
      ]
