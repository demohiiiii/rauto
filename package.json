{
  "name": "rauto-web-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "prepare": "npm run hooks:install || true",
    "hooks:install": "git config core.hooksPath .githooks",
    "format": "cargo fmt --all && npm run frontend:format",
    "format:check": "cargo fmt --all --check && npm run frontend:format:check",
    "clippy": "cargo clippy --all-targets --all-features -- -D warnings",
    "frontend:format": "prettier --write \"frontend/**/*.{js,mjs,svelte,css,html}\" package.json vite.config.js",
    "frontend:format:check": "prettier --check \"frontend/**/*.{js,mjs,svelte,css,html}\" package.json vite.config.js",
    "frontend:dev": "vite --host 127.0.0.1",
    "frontend:build": "vite build",
    "frontend:preview": "vite preview --host 127.0.0.1",
    "web:build": "npm run frontend:build"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.23.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.1",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@fontsource-variable/geist": "^5.2.9",
    "@xyflow/svelte": "^1.6.2",
    "codemirror": "^6.0.2",
    "smol-toml": "^1.7.0",
    "svelte-codemirror-editor": "^2.1.0"
  }
}
